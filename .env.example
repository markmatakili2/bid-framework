# Admin dashboard password (default: tuinnov8-admin)
ADMIN_PASSWORD=mark-admin

# API server port (default: 3001)
PORT=3001

# Optional: enable live AI-generated report insights
OPENAI_API_KEY=

# Optional: override AI model and endpoint
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=https://api.openai.com/v1
