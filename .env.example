# Tuinnov8 BID — Environment Variables
# Copy this to .env for local development

PORT=3000
NODE_ENV=development

# Admin credentials (CHANGE THESE before deploying)
ADMIN_USER=admin
ADMIN_PASS=tuinnov8admin

# Session secret — use a long random string in production
SESSION_SECRET=change-this-to-a-long-random-string

# PostgreSQL — Render injects this automatically via render.yaml
# For local dev: postgres://postgres:password@localhost:5432/tuinnov8
DATABASE_URL=postgres://postgres:password@localhost:5432/tuinnov8
